{
  "name": "@tomcp/server",
  "version": "0.1.0",
  "description": "Server-side utilities for Transfer over MCP",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bhanquier/tomcp.git",
    "directory": "packages/server"
  },
  "keywords": ["mcp", "model-context-protocol", "transfer", "agent", "llm"],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@tomcp/types": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
